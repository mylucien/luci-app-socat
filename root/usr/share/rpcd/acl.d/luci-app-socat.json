{
	"luci-app-socat": {
		"description": "Grant UCI access for luci-app-socat",
		"read": {
			"uci": ["socat"],
			"ubus": {
				"service": ["list"]
			},
			"file": {
				"/var/run/socat/*.pid": ["read"]
			}
		},
		"write": {
			"uci": ["socat"],
			"ubus": {
				"service": ["set", "list", "delete", "signal", "update"]
			}
		}
	}
}
